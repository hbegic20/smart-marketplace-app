# ------------------------------
# Agent integration (NestJS backend)
# ------------------------------
# Base URL only; frontend proxies append specific paths:
# - /api/v1/public/agent/marketplace
# - /api/v1/agent/marketplace
# - /api/v1/admin/listings
AGENT_API_BASE_URL=http://localhost:4000

# ------------------------------
# Existing marketplace settings
# ------------------------------
OPENAI_API_KEY=sk-...
MAPS_PROVIDER=google
GOOGLE_MAPS_API_KEY=your_google_maps_key
MAPBOX_ACCESS_TOKEN=your_mapbox_server_token
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token
